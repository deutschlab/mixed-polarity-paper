%%  core_pipeline_map.mmd
%%  Core pipeline: raw inputs → processing scripts → derived tables → figure scripts
%%  Render with: mermaid-js / VS Code Mermaid extension / mmdc
%%  Deferred groups (Fig7, supp_uncertain) are shown in grey.

flowchart TD

    %% ── RAW INPUTS ─────────────────────────────────────────────
    subgraph RAW["Raw Inputs  (data/raw/ — not committed)"]
        direction TB
        CSV["Princeton synapse CSV\nfafb_v783_princeton_synapse_table.csv"]
        SWC["SWC skeletons\nswc/783/"]
        ANN["Neuron annotations\nSupplemental_file1_neuron_annotations.csv\n+ cell_stats.csv + neurons.csv"]
        RNK["Rank feathers\nranks/"]
        RAW_EXTRA["classification.csv\nneuropil CSV\nlarva feathers"]
    end

    %% ── PROCESSING PIPELINE ────────────────────────────────────
    subgraph PROC["Processing Pipeline  (processing/)"]
        direction TB
        P01["01_extract_compartments_SI\nAssign axon/dendrite compartments,\ncompute SI — standard neurons"]
        P02A["02a_large_neurons_pipeline\nSame as 01, large-neuron batch"]
        P02B["02b_merge_connectors\nCollect per-neuron PKLs → connector FTRs"]
        P03["03_merge_synapses_connectors\nJoin Princeton CSV with connector tables"]
        P04["04_build_master_synapse_table\nAdd AA/AD/DA/DD labels, SI_pre, SI_post"]
        P05["05_build_neuron_metadata_table\nAggregate to per-neuron: SI, morphology,\ncell-type annotations, rank scores"]
        P06["06_build_connection_reciprocity_table\nPer-connection synapse-type counts,\nreciprocity labels"]
        P07["07_pca_morphology\nPCA of morphological features"]
    end

    %% ── DERIVED TABLES ─────────────────────────────────────────
    subgraph TABLES["Core Derived Tables  (data/derived/ — not committed)"]
        direction TB
        T_SYN["synapses_783_article_princeton.ftr\nper-synapse: comp, SI_pre, SI_post, npil"]
        T_NEU["neuron_data_full_article_princeton.ftr\nper-neuron: SI, type, morphology, counts"]
        T_CON["connections_by_syn_type_reciprocal_types\n_filtered_article_princeton.ftr\nper-connection: AA/AD/DA/DD, reciprocal"]
        T_PCA["neurons_pca_princeton.ftr\nper-neuron PC1, PC2"]
        T_SI["SI_updated.ftr"]
        T_REC["reci_prop_princeton.ftr\n(generated by fig5/reciprocal_fraction.py)"]
        T_RFC["full_reci_connections_article_filtered\n_princeton.ftr"]
    end

    %% ── FIGURE SCRIPTS ─────────────────────────────────────────
    subgraph FIGS["Figure Scripts  (figures/figN/) → outputs/figN/"]
        direction TB
        F1["Fig 1  (6 scripts)\nSI distributions, canonicality,\ncompartment split examples"]
        F2["Fig 2  (11 scripts)\nSI vs super-class, NT type,\nmorphology models, adult/larva"]
        F3["Fig 3  (13 scripts)\nSynapse-type composition,\nidentity, classifiers"]
        F4["Fig 4  (3 scripts)\nSynapse type × PC1 model"]
        F5["Fig 5  (8 scripts)\nReciprocal connectivity,\nsynapse-type patterns"]
    end

    %% ── DEFERRED / SUPPLEMENTARY ───────────────────────────────
    subgraph DEFER["Deferred / Supplementary  (excluded from initial release)"]
        direction TB
        F67["Fig 7 / filopodia\nfigures/fig6_7/\nDeferred — py_compile failures,\nhardcoded paths, missing data"]

        SUPP["supp_uncertain/\nDeferred — py_compile failures"]
    end

    %% ── EDGES: raw → processing ─────────────────────────────────
    CSV --> P01
    SWC --> P01
    CSV --> P02A
    SWC --> P02A
    P01 --> P02B
    P02A --> P02B
    P02B --> P03
    CSV --> P03
    P03 --> P04
    P01 --> P04
    P02A --> P04

    %% ── EDGES: processing → derived tables ──────────────────────
    P04 --> T_SYN
    ANN --> P05
    RNK --> P05
    T_SYN --> P05
    P05 --> T_NEU
    P05 --> T_SI
    T_SYN --> P06
    T_NEU --> P06
    P06 --> T_CON
    P06 --> T_RFC
    T_NEU --> P07
    P07 --> T_PCA

    %% ── EDGES: derived tables → figures ─────────────────────────
    T_SYN --> F1
    T_NEU --> F1

    T_SYN --> F2
    T_NEU --> F2
    T_SI  --> F2
    RAW_EXTRA --> F2

    T_SYN --> F3
    T_NEU --> F3
    T_SI  --> F3
    RAW_EXTRA --> F3

    T_NEU --> F4
    T_CON --> F4
    T_PCA --> F4

    T_CON --> F5
    T_NEU --> F5
    T_RFC --> F5
    F5 --> T_REC

    %% ── STYLING ─────────────────────────────────────────────────
    classDef raw        fill:#e8f4f8,stroke:#4a90d9,color:#1a1a1a
    classDef proc       fill:#fff8e7,stroke:#f0a500,color:#1a1a1a
    classDef table      fill:#eafaea,stroke:#3aaa3a,color:#1a1a1a
    classDef fig        fill:#f3eaff,stroke:#8a4aba,color:#1a1a1a
    classDef deferred   fill:#f5f5f5,stroke:#aaaaaa,color:#777777

    class CSV,SWC,ANN,RNK,RAW_EXTRA raw
    class P01,P02A,P02B,P03,P04,P05,P06,P07 proc
    class T_SYN,T_NEU,T_CON,T_PCA,T_SI,T_REC,T_RFC table
    class F1,F2,F3,F4,F5 fig
    class F67,SUPP deferred
